{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "{templates/**,static/**,app.py,export_cache.py,formulas.py,monte_carlo.py,report.py,report_*.py}"
    }
  }
}
